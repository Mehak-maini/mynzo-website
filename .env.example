# Copy this file to .env and fill in your values

# Required: a long random secret string (generate one at https://generate-secret.vercel.app/32)
PAYLOAD_SECRET=your-long-random-secret-here

# Neon PostgreSQL connection string (get this from neon.tech after creating a database)
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# Your site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
